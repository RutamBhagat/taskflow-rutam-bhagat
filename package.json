{
  "name": "taskflow-elysia",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:server": "bun run --filter server dev",
    "db:push": "bun run --filter @taskflow-elysia/db db:push",
    "db:studio": "bun run --filter @taskflow-elysia/db db:studio",
    "db:generate": "bun run --filter @taskflow-elysia/db db:generate",
    "db:migrate:up": "bun run --filter @taskflow-elysia/db db:migrate:up",
    "db:migrate:down": "bun run --filter @taskflow-elysia/db db:migrate:down",
    "db:migrate:status": "bun run --filter @taskflow-elysia/db db:migrate:status",
    "db:migrate:fresh": "bun run --filter @taskflow-elysia/db db:migrate:fresh",
    "db:migrate:refresh": "bun run --filter @taskflow-elysia/db db:migrate:refresh",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@taskflow-elysia/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@taskflow-elysia/config": "workspace:*",
    "@types/bun": "catalog:",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.3"
}
