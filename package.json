{
  "name": "taskflow-elysia",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "dev:server": "bun run --filter server dev",
    "db:push": "bun run --filter @taskflow-elysia/db db:push",
    "db:studio": "bun run --filter @taskflow-elysia/db db:studio",
    "db:generate": "bun run --filter @taskflow-elysia/db db:generate",
    "db:migrate": "bun run --filter @taskflow-elysia/db db:migrate",
    "db:start": "bun run --filter @taskflow-elysia/db db:start",
    "db:watch": "bun run --filter @taskflow-elysia/db db:watch",
    "db:stop": "bun run --filter @taskflow-elysia/db db:stop",
    "db:down": "bun run --filter @taskflow-elysia/db db:down",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@taskflow-elysia/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@taskflow-elysia/config": "workspace:*",
    "@types/bun": "catalog:",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.3"
}
